# WaveSight EMC — Production Environment
# Copy to .env.prod and fill in real values

# Database
POSTGRES_DB=wavesight
POSTGRES_USER=wavesight
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+psycopg2://wavesight:CHANGE_ME_STRONG_PASSWORD@db:5432/wavesight

# Auth
JWT_SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# CORS — set to your actual domain
CORS_ORIGINS=https://app.wavesight.com

# AI (optional)
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Storage (optional)
S3_BUCKET=
S3_REGION=us-east-1

# Server
PORT=8080
LOG_LEVEL=INFO
